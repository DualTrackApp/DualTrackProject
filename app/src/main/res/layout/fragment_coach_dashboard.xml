<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dt_navy"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <include
            android:id="@+id/logo"
            layout="@layout/include_dualtrack_logo"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvWelcome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Welcome Coach!"
            android:textColor="@color/dt_white"
            android:textSize="22sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/logo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardCoachBanner"
            android:layout_width="0dp"
            android:layout_height="200dp"
            android:layout_marginTop="18dp"
            app:cardBackgroundColor="@color/dt_navy"
            app:cardCornerRadius="22dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/dt_white_60"
            app:strokeWidth="2dp"
            app:layout_constraintTop_toBottomOf="@id/tvWelcome"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <ImageView
                    android:id="@+id/ivCoachBanner"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/banner_coach_home"
                    android:contentDescription="@string/app_name" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#4D0D2D73" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="bottom"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:id="@+id/tvCoachBannerTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lead your team."
                        android:textColor="@color/dt_white"
                        android:textSize="28sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvCoachBannerSubtitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Post updates, assign forms, review player status, and stay on top of risk and wellness."
                        android:textColor="@color/dt_white"
                        android:textSize="15sp" />
                </LinearLayout>
            </FrameLayout>
        </com.google.android.material.card.MaterialCardView>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/btnRow"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            app:layout_constraintTop_toBottomOf="@id/cardCoachBanner"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <Button
                android:id="@+id/btnAddAnnouncement"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:background="@drawable/dt_button_pill_white_orange"
                android:paddingHorizontal="20dp"
                android:paddingVertical="10dp"
                android:text="Create Announcement"
                android:textAllCaps="false"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/btnAddEvent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintHorizontal_chainStyle="spread" />

            <Button
                android:id="@+id/btnAddEvent"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:background="@drawable/dt_button_pill_white_orange"
                android:paddingHorizontal="20dp"
                android:paddingVertical="10dp"
                android:text="Add Event"
                android:textAllCaps="false"
                app:layout_constraintStart_toEndOf="@id/btnAddAnnouncement"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <Button
            android:id="@+id/btnSendForms"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/dt_button_pill_white_orange"
            android:paddingVertical="12dp"
            android:text="Send Forms"
            android:textAllCaps="false"
            app:layout_constraintTop_toBottomOf="@id/btnRow"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <Button
            android:id="@+id/btnReviewTeam"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/dt_button_pill_white_orange"
            android:paddingVertical="12dp"
            android:text="Review Team"
            android:textAllCaps="false"
            app:layout_constraintTop_toBottomOf="@id/btnSendForms"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvAthleteTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="Athlete Assignment"
            android:textColor="@color/dt_white"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/btnReviewTeam"
            app:layout_constraintStart_toStartOf="parent" />

        <ImageView
            android:id="@+id/ivAthleteArrow"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_marginStart="8dp"
            android:src="@drawable/ic_plus_circle"
            app:tint="@color/dt_white"
            app:layout_constraintStart_toEndOf="@id/tvAthleteTitle"
            app:layout_constraintBottom_toBottomOf="@id/tvAthleteTitle"
            app:layout_constraintTop_toTopOf="@id/tvAthleteTitle" />

        <TextView
            android:id="@+id/tvAthleteSubtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="View roster status and assigned athletes."
            android:textColor="@color/dt_white_60"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/tvAthleteTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardAthletes"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:cardBackgroundColor="#F4F7FB"
            app:cardCornerRadius="22dp"
            app:cardElevation="0dp"
            app:strokeColor="#D8E2F0"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toBottomOf="@id/tvAthleteSubtitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvAthletes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:padding="14dp" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvFlagsTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="At-Risk Flags"
            android:textColor="@color/dt_white"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/cardAthletes"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tvFlagsSubtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="See players who need coach attention first."
            android:textColor="@color/dt_white_60"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/tvFlagsTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardFlags"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:cardBackgroundColor="#F4F7FB"
            app:cardCornerRadius="22dp"
            app:cardElevation="0dp"
            app:strokeColor="#D8E2F0"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toBottomOf="@id/tvFlagsSubtitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvFlags"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:padding="14dp" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvWellnessTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Wellness Trends"
            android:textColor="@color/dt_white"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/cardFlags"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tvWellnessSubtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Monitor players tied to wellness follow-up."
            android:textColor="@color/dt_white_60"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/tvWellnessTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardWellness"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:cardBackgroundColor="#F4F7FB"
            app:cardCornerRadius="22dp"
            app:cardElevation="0dp"
            app:strokeColor="#D8E2F0"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toBottomOf="@id/tvWellnessSubtitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvWellness"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:padding="14dp" />
        </com.google.android.material.card.MaterialCardView>

        <Button
            android:id="@+id/btnTeamForms"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/dt_button_pill_white_orange"
            android:paddingVertical="12dp"
            android:text="Review Team Forms"
            android:textAllCaps="false"
            app:layout_constraintTop_toBottomOf="@id/cardWellness"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <Button
            android:id="@+id/btnManageTeam"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/dt_button_pill_white_orange"
            android:paddingVertical="12dp"
            android:text="Manage Team"
            android:textAllCaps="false"
            app:layout_constraintTop_toBottomOf="@id/btnTeamForms"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>