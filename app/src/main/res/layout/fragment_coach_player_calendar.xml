<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"

    android:layout_width="match_parent"

    android:layout_height="match_parent"

    android:orientation="vertical"

    android:background="@color/dt_navy"

    android:padding="16dp">



    <ImageButton

        android:id="@+id/btnBack"

        android:layout_width="40dp"

        android:layout_height="40dp"

        android:background="@android:color/transparent"

        android:src="@android:drawable/ic_media_previous"

        android:contentDescription="Back"

        android:padding="8dp"

        android:tint="@color/dt_white" />



    <TextView

        android:id="@+id/tvPlayerTitle"

        android:layout_width="match_parent"

        android:layout_height="wrap_content"

        android:layout_marginTop="12dp"

        android:text="Player Weekly Calendar"

        android:textColor="@color/dt_white"

        android:textSize="24sp"

        android:textStyle="bold" />



    <TextView

        android:id="@+id/tvWeekRange"

        android:layout_width="match_parent"

        android:layout_height="wrap_content"

        android:layout_marginTop="8dp"

        android:text="Mar 25 - Mar 31"

        android:textColor="@color/dt_white_60"

        android:textSize="14sp" />



    <TextView

        android:id="@+id/tvWeeklyHeader"

        android:layout_width="match_parent"

        android:layout_height="wrap_content"

        android:layout_marginTop="20dp"

        android:layout_marginBottom="10dp"

        android:text="Weekly Calendar"

        android:textColor="@color/dt_white"

        android:textSize="18sp"

        android:textStyle="bold" />



    <androidx.recyclerview.widget.RecyclerView

        android:id="@+id/rvWeek"

        android:layout_width="match_parent"

        android:layout_height="wrap_content"

        android:overScrollMode="never" />



</LinearLayout>