<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"

    android:layout_width="match_parent"

    android:layout_height="match_parent"

    android:background="@color/dt_navy"

    android:fillViewport="true">



    <LinearLayout

        android:layout_width="match_parent"

        android:layout_height="wrap_content"

        android:orientation="vertical"

        android:padding="24dp">



        <ImageButton

            android:id="@+id/btnBack"

            android:layout_width="40dp"

            android:layout_height="40dp"

            android:background="@android:color/transparent"

            android:contentDescription="Back"

            android:padding="8dp"

            android:src="@android:drawable/ic_media_previous"

            android:tint="@color/dt_white" />



        <TextView

            android:layout_width="wrap_content"

            android:layout_height="wrap_content"

            android:layout_marginTop="12dp"

            android:text="At-Risk Alert"

            android:textColor="@color/dt_white"

            android:textSize="24sp"

            android:textStyle="bold" />



        <TextView

            android:layout_width="match_parent"

            android:layout_height="wrap_content"

            android:layout_marginTop="8dp"

            android:text="Instruction: Use this form to document a concern that may affect athlete performance, academics, behavior, or overall well-being."

            android:textColor="@color/dt_white_60"

            android:textSize="14sp" />



        <TextView

            android:layout_width="wrap_content"

            android:layout_height="wrap_content"

            android:layout_marginTop="20dp"

            android:text="Risk Details"

            android:textColor="@color/dt_white"

            android:textSize="18sp"

            android:textStyle="bold" />



        <Spinner

            android:id="@+id/spAlertType"

            android:layout_width="match_parent"

            android:layout_height="wrap_content"

            android:layout_marginTop="12dp"

            android:background="@drawable/bg_spinner_white"

            android:entries="@array/at_risk_types" />



        <EditText

            android:id="@+id/etConcernArea"

            android:layout_width="match_parent"

            android:layout_height="wrap_content"

            android:layout_marginTop="12dp"

            android:background="@drawable/dt_input_outline"

            android:hint="Primary concern area *"

            android:inputType="textCapSentences"

            android:padding="12dp"

            android:textColor="@color/dt_white"

            android:textColorHint="@color/dt_white_60" />



        <EditText

            android:id="@+id/etIncidentDate"

            android:layout_width="match_parent"

            android:layout_height="wrap_content"

            android:layout_marginTop="12dp"

            android:background="@drawable/dt_input_outline"

            android:hint="Date concern was noticed *"

            android:padding="12dp"

            android:textColor="@color/dt_white"

            android:textColorHint="@color/dt_white_60" />



        <EditText

            android:id="@+id/etObservedBehavior"

            android:layout_width="match_parent"

            android:layout_height="100dp"

            android:layout_marginTop="12dp"

            android:background="@drawable/dt_input_outline"

            android:gravity="top"

            android:hint="Observed behavior / situation *"

            android:inputType="textCapSentences|textMultiLine"

            android:padding="12dp"

            android:textColor="@color/dt_white"

            android:textColorHint="@color/dt_white_60" />



        <Spinner

            android:id="@+id/spImpactLevel"

            android:layout_width="match_parent"

            android:layout_height="wrap_content"

            android:layout_marginTop="12dp"

            android:background="@drawable/bg_spinner_white" />



        <EditText

            android:id="@+id/etActionsTaken"

            android:layout_width="match_parent"

            android:layout_height="100dp"

            android:layout_marginTop="12dp"

            android:background="@drawable/dt_input_outline"

            android:gravity="top"

            android:hint="Actions already taken"

            android:inputType="textCapSentences|textMultiLine"

            android:padding="12dp"

            android:textColor="@color/dt_white"

            android:textColorHint="@color/dt_white_60" />



        <Spinner

            android:id="@+id/spFollowUp"

            android:layout_width="match_parent"

            android:layout_height="wrap_content"

            android:layout_marginTop="12dp"

            android:background="@drawable/bg_spinner_white" />



        <EditText

            android:id="@+id/etMessage"

            android:layout_width="match_parent"

            android:layout_height="120dp"

            android:layout_marginTop="12dp"

            android:background="@drawable/dt_input_outline"

            android:gravity="top"

            android:hint="Summary / additional notes *"

            android:inputType="textCapSentences|textMultiLine"

            android:padding="12dp"

            android:textColor="@color/dt_white"

            android:textColorHint="@color/dt_white_60" />



        <Button

            android:id="@+id/btnSubmitAtRisk"

            android:layout_width="match_parent"

            android:layout_height="wrap_content"

            android:layout_marginTop="28dp"

            android:background="@drawable/dt_button_pill_white_orange"

            android:text="Submit Alert"

            android:textAllCaps="false" />



    </LinearLayout>

</ScrollView>
